<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Duty Manager Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080c14;
  --surface: #0e1420;
  --surface2: #141b2d;
  --surface3: #1c2540;
  --border: #1e2d4a;
  --border2: #243558;
  --accent: #3b82f6;
  --accent-glow: rgba(59,130,246,0.18);
  --accent2: #8b5cf6;
  --green: #10b981;
  --green-dim: rgba(16,185,129,0.12);
  --warn: #f59e0b;
  --warn-dim: rgba(245,158,11,0.12);
  --red: #ef4444;
  --red-dim: rgba(239,68,68,0.12);
  --text: #e2e8f8;
  --text2: #7d90b8;
  --text3: #3d5080;
  --weekend-bg: #0f1a2e;
  --weekend-border: #1e3a5f;
  --holiday-bg: #120f1e;
  --holiday-border: #3b1f5e;
  --regular-bg: #0e1420;
  --font: 'Sora', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}
body::before {
  content: '';
  position: fixed;
  top: -200px; left: -200px;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(59,130,246,0.04) 0%, transparent 70%);
  pointer-events: none; z-index: 0;
}

/* TOPBAR */
.topbar {
  position: sticky; top: 0; z-index: 200;
  background: rgba(8,12,20,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  padding: 0 20px;
  height: 56px;
  display: flex; align-items: center; gap: 12px;
}
.brand { display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 700; white-space: nowrap; }
.brand-icon {
  width: 28px; height: 28px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 800; color: #fff;
  box-shadow: 0 0 14px rgba(59,130,246,0.4);
  flex-shrink: 0;
}
.spacer { flex: 1; }
.month-pill {
  display: flex; align-items: center; gap: 6px;
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 7px; padding: 4px 10px;
}
.month-pill select, .month-pill input {
  background: transparent; border: none; outline: none;
  color: var(--text); font-family: var(--font); font-size: 12px; font-weight: 500; cursor: pointer;
}
.month-pill input[type=number] { width: 52px; }
.sync-badge {
  font-size: 10px; padding: 3px 9px; border-radius: 5px;
  font-weight: 600; white-space: nowrap; transition: all .3s;
}
.sync-badge.connected    { background: rgba(16,185,129,0.15); color: var(--green); border: 1px solid rgba(16,185,129,0.3); }
.sync-badge.syncing      { background: rgba(245,158,11,0.15); color: var(--warn);  border: 1px solid rgba(245,158,11,0.3); }
.sync-badge.disconnected { background: rgba(239,68,68,0.15);  color: var(--red);   border: 1px solid rgba(239,68,68,0.3); }
.btn {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 6px 12px; border-radius: 6px;
  font-family: var(--font); font-size: 11px; font-weight: 600;
  cursor: pointer; border: none; transition: all .15s; white-space: nowrap;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: #5b96ff; box-shadow: 0 0 14px rgba(59,130,246,0.4); }
.btn-ghost { background: transparent; border: 1px solid var(--border2); color: var(--text2); }
.btn-ghost:hover { border-color: var(--accent); color: var(--text); }
.btn-green { background: var(--green); color: #fff; }
.btn-green:hover { background: #34d399; }
.btn-warn { background: var(--warn); color: #000; font-weight: 700; }
.btn-warn:hover { background: #fbbf24; }
.btn-danger { background: var(--red); color: #fff; }

/* TAB BAR */
.tab-bar {
  background: var(--surface); border-bottom: 1px solid var(--border);
  padding: 0 20px; display: flex; gap: 2px; overflow-x: auto; flex-shrink: 0;
}
.tab-bar::-webkit-scrollbar { height: 3px; }
.tab-bar::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
.tab-btn {
  padding: 11px 14px; font-family: var(--font); font-size: 11px; font-weight: 500;
  color: var(--text3); background: transparent; border: none; cursor: pointer;
  border-bottom: 2px solid transparent; white-space: nowrap; transition: all .15s;
  display: flex; align-items: center; gap: 6px;
}
.tab-btn:hover { color: var(--text2); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.tab-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.dot-wh { background: #f59e0b; }
.dot-co { background: #10b981; }
.dot-po { background: #3b82f6; }
.dot-go { background: #8b5cf6; }
.dot-gk { background: #ec4899; }

/* MAIN WRAP */
.main-wrap {
  display: flex;
  height: calc(100vh - 56px - 43px - 44px);
  overflow: hidden;
}

/* SIDEBAR */
.sidebar {
  width: 210px; min-width: 210px;
  background: var(--surface); border-right: 1px solid var(--border);
  overflow-y: auto; padding: 10px 6px; flex-shrink: 0;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
.sidebar-label { padding: 6px 10px 4px; font-size: 9px; font-weight: 700; letter-spacing: 1.2px; color: var(--text3); text-transform: uppercase; }
.prop-btn {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 6px 10px; background: transparent; border: none; border-radius: 5px;
  color: var(--text2); font-family: var(--font); font-size: 11px; text-align: left; cursor: pointer;
  transition: all .12s; gap: 6px;
}
.prop-btn:hover { background: var(--surface2); color: var(--text); }
.prop-btn.active { background: var(--accent-glow); color: var(--accent); font-weight: 600; }
.prop-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.fill-badge { font-size: 9px; color: var(--text3); font-family: var(--mono); flex-shrink: 0; }
.prop-btn.active .fill-badge { color: var(--accent); }
.prop-btn.prop-complete .fill-badge { color: var(--green); }

/* GRID AREA */
.grid-area { flex: 1; overflow-y: auto; padding: 16px 20px; }
.grid-area::-webkit-scrollbar { width: 5px; }
.grid-area::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* LEGEND */
.legend-bar {
  display: flex; align-items: center; gap: 14px; margin-bottom: 14px;
  padding: 9px 13px; background: var(--surface); border: 1px solid var(--border);
  border-radius: 7px; font-size: 11px; color: var(--text2); flex-wrap: wrap;
}
.legend-item { display: flex; align-items: center; gap: 5px; }
.legend-swatch { width: 11px; height: 11px; border-radius: 3px; }
.swatch-regular { background: var(--surface3); border: 1px solid var(--border); }
.swatch-weekend { background: var(--weekend-bg); border: 1px solid var(--weekend-border); }
.swatch-holiday { background: var(--holiday-bg); border: 1px solid var(--holiday-border); }

/* PROGRESS */
.progress-header { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.progress-info { font-size: 11px; color: var(--text2); white-space: nowrap; }
.progress-bar-wrap { flex: 1; height: 4px; background: var(--surface3); border-radius: 2px; overflow: hidden; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 2px; transition: width .4s ease; }

/* DATE ROWS */
.date-grid { display: flex; flex-direction: column; gap: 5px; }
.date-row {
  display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 7px;
  border: 1px solid var(--border); background: var(--regular-bg); transition: border-color .15s;
}
.date-row:hover { border-color: var(--border2); }
.date-row.weekend { background: var(--weekend-bg); border-color: var(--weekend-border); }
.date-row.holiday { background: var(--holiday-bg); border-color: var(--holiday-border); }
.date-row.has-value { border-left: 3px solid var(--green); }
.date-row.weekend.has-value { border-left: 3px solid var(--warn); }
.date-row.holiday.has-value { border-left: 3px solid var(--accent2); }
.date-label { min-width: 64px; font-family: var(--mono); font-size: 12px; font-weight: 500; color: var(--text); }
.day-label { min-width: 72px; font-size: 10px; color: var(--text3); }
.date-row.weekend .day-label { color: var(--warn); }
.date-row.holiday .day-label { color: var(--accent2); }
.holiday-name {
  font-size: 9px; color: var(--accent2); background: rgba(139,92,246,0.12);
  border: 1px solid rgba(139,92,246,0.25); border-radius: 3px; padding: 2px 6px; white-space: nowrap;
}
.name-input {
  flex: 1; background: transparent; border: 1px solid transparent;
  border-radius: 5px; color: var(--text); font-family: var(--font); font-size: 12px;
  padding: 5px 9px; outline: none; transition: all .15s;
}
.name-input:hover { border-color: var(--border2); background: var(--surface2); }
.name-input:focus { border-color: var(--accent); background: var(--surface2); box-shadow: 0 0 0 3px var(--accent-glow); }
.name-input::placeholder { color: var(--text3); }
.name-input.filled { font-weight: 500; }
.saving-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--warn); flex-shrink: 0; display: none;
  animation: pulse 1s ease infinite;
}
.saving-dot.active { display: block; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
.clear-btn {
  background: transparent; border: none; color: var(--text3); font-size: 13px;
  cursor: pointer; padding: 3px 5px; border-radius: 4px; transition: all .12s;
  opacity: 0; pointer-events: none;
}
.date-row:hover .clear-btn, .date-row.has-value .clear-btn { opacity: 1; pointer-events: all; }
.clear-btn:hover { color: var(--red); background: var(--red-dim); }

/* REVIEW VIEW */
.review-outer { height: calc(100vh - 56px - 43px); overflow-y: auto; padding: 20px 24px; }
.review-outer::-webkit-scrollbar { width: 5px; }
.review-outer::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
.review-title { font-size: 17px; font-weight: 700; }
.review-subtitle { font-size: 12px; color: var(--text2); margin-top: 3px; }
.stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; margin: 16px 0; }
.stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; }
.stat-num { font-size: 20px; font-weight: 700; font-family: var(--mono); }
.stat-label { font-size: 10px; color: var(--text3); margin-top: 2px; }
.toolbar { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.search-input {
  background: var(--surface2); border: 1px solid var(--border); border-radius: 6px;
  color: var(--text); font-family: var(--font); font-size: 12px; padding: 6px 11px;
  outline: none; width: 190px; transition: all .15s;
}
.search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
.search-input::placeholder { color: var(--text3); }
.filter-btn {
  padding: 5px 11px; border-radius: 5px; border: 1px solid var(--border);
  background: transparent; color: var(--text2); font-family: var(--font); font-size: 10px;
  font-weight: 600; cursor: pointer; transition: all .12s;
}
.filter-btn.active { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }
.filter-btn:hover:not(.active) { border-color: var(--border2); color: var(--text); }
.review-section { margin-bottom: 24px; }
.review-section-title {
  font-size: 11px; font-weight: 700; letter-spacing: .7px; text-transform: uppercase;
  color: var(--text2); padding-bottom: 7px; border-bottom: 1px solid var(--border);
  margin-bottom: 10px; display: flex; align-items: center; gap: 7px;
}
.review-table-wrap { overflow-x: auto; border-radius: 7px; border: 1px solid var(--border); }
.review-table { width: 100%; border-collapse: collapse; font-size: 11px; }
.review-table th {
  text-align: left; padding: 7px 10px; background: var(--surface2); color: var(--text2);
  font-weight: 600; font-size: 10px; letter-spacing: .3px; border-bottom: 1px solid var(--border);
  white-space: nowrap; position: sticky; top: 0;
}
.review-table td { padding: 6px 10px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: middle; }
.review-table tr:last-child td { border-bottom: none; }
.review-table tr.weekend-row td:first-child { color: var(--warn); font-weight: 600; }
.review-table tr.holiday-row td:first-child { color: var(--accent2); font-weight: 600; }
.review-table tr:hover td { background: var(--surface2); }
.empty-cell { color: var(--text3); font-style: italic; }
.filled-cell { font-weight: 500; }

/* EXPORT BAR */
.export-bar {
  height: 44px; padding: 0 20px; background: var(--surface); border-top: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px; flex-shrink: 0;
}
.export-label { font-size: 11px; color: var(--text2); }

/* LOADING OVERLAY */
.loading-overlay {
  position: fixed; inset: 0; background: rgba(8,12,20,0.92);
  backdrop-filter: blur(6px); z-index: 999;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
}
.loading-spinner {
  width: 36px; height: 36px; border: 3px solid var(--border2);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 12px; color: var(--text2); }

/* TOAST */
.toast-wrap { position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 7px; z-index: 999; pointer-events: none; }
.toast {
  background: var(--surface2); border: 1px solid var(--border2); border-radius: 7px;
  padding: 9px 14px; font-size: 12px; color: var(--text); box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  animation: slideIn .2s ease, fadeOut .3s ease 2.5s forwards; display: flex; align-items: center; gap: 7px;
}
@keyframes slideIn { from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)} }
@keyframes fadeOut { from{opacity:1}to{opacity:0} }

/* MODAL */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.72); backdrop-filter: blur(4px);
  z-index: 500; display: flex; align-items: center; justify-content: center; padding: 20px;
  animation: fadeIn .15s ease;
}
@keyframes fadeIn { from{opacity:0}to{opacity:1} }
.modal {
  background: var(--surface); border: 1px solid var(--border2); border-radius: 10px;
  padding: 24px; max-width: 440px; width: 100%;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6); animation: slideUp .2s ease;
}
@keyframes slideUp { from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)} }
.modal h3 { font-size: 15px; margin-bottom: 8px; }
.modal p { font-size: 12px; color: var(--text2); margin-bottom: 18px; line-height: 1.6; }
.modal-footer { display: flex; gap: 8px; justify-content: flex-end; }

/* EMPTY STATE */
.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 10px; padding: 50px 20px; color: var(--text3); text-align: center;
}
.empty-icon { font-size: 36px; }
.empty-title { font-size: 13px; font-weight: 600; color: var(--text2); }
.empty-sub { font-size: 11px; }

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
</style>
</head>
<body>

<!-- LOADING OVERLAY -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text" id="loadingText">Connecting to database…</div>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="brand">
    <div class="brand-icon">DM</div>
    <span>Duty Manager Tracker</span>
  </div>
  <div class="spacer"></div>
  <span class="sync-badge connected" id="syncBadge">● Live</span>
  <div class="month-pill">
    <select id="selMonth">
      <option value="0">January</option><option value="1">February</option>
      <option value="2">March</option><option value="3">April</option>
      <option value="4">May</option><option value="5">June</option>
      <option value="6">July</option><option value="7">August</option>
      <option value="8">September</option><option value="9">October</option>
      <option value="10">November</option><option value="11">December</option>
    </select>
    <span style="color:var(--text3);font-size:11px">|</span>
    <input type="number" id="selYear" value="2026" min="2020" max="2040">
  </div>
  <button class="btn btn-ghost" id="btnReview" onclick="toggleView()">👁 Review</button>
  <button class="btn btn-green" onclick="exportCSV()">⬇ CSV</button>
  <button class="btn btn-warn" onclick="confirmClear()">🗑 Clear</button>
</div>

<!-- TAB BAR -->
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('wh',this)"><span class="tab-dot dot-wh"></span>Weekend &amp; Holiday DM</button>
  <button class="tab-btn" onclick="switchTab('co',this)"><span class="tab-dot dot-co"></span>Closing Officers</button>
  <button class="tab-btn" onclick="switchTab('po',this)"><span class="tab-dot dot-po"></span>Pre-Opening Briefing</button>
  <button class="tab-btn" onclick="switchTab('go',this)"><span class="tab-dot dot-go"></span>Graveyard Officer</button>
  <button class="tab-btn" onclick="switchTab('gk',this)"><span class="tab-dot dot-gk"></span>Graveyard Key Agency</button>
</div>

<!-- INPUT VIEW -->
<div id="inputView">
  <div class="main-wrap">
    <div class="sidebar" id="sidebar"></div>
    <div class="grid-area" id="gridArea"></div>
  </div>
  <div class="export-bar">
    <span class="export-label">Master File:</span>
    <button class="btn btn-primary" onclick="exportCSV()">⬇ Download CSV</button>
    <button class="btn btn-ghost" onclick="exportJSON()">⬇ Download JSON</button>
    <span id="saveStatus" style="font-size:11px;color:var(--green);"></span>
    <div class="spacer"></div>
    <span style="font-size:10px;color:var(--text3)">Last saved: <span id="lastSaved">—</span></span>
  </div>
</div>

<!-- REVIEW VIEW -->
<div id="reviewView" style="display:none;">
  <div class="review-outer" id="reviewContent"></div>
</div>

<!-- TOAST -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- CLEAR MODAL -->
<div id="clearModal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <h3>⚠️ Clear Month Data</h3>
    <p>This will permanently delete all entered names for <strong id="clearMonthLabel"></strong>. This cannot be undone and affects all users.</p>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="document.getElementById('clearModal').style.display='none'">Cancel</button>
      <button class="btn btn-danger" onclick="clearMonth()">Yes, Clear All</button>
    </div>
  </div>
</div>

