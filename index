// ── STATE ─────────────────────────────────────────────────────
let currentTab   = 'wh';
let currentProp  = MAIN_PROPS[0];
let isReviewMode = false;
let reviewFilter = 'all';
let searchQuery  = '';
let monthData    = {};       // live in-memory mirror of Firebase for current month
let activeListener = null;  // current Firebase onValue unsubscribe ref
let saveTimers   = {};       // debounce timers per cell key
let pendingSaves = new Set(); // keys currently being saved

// ── INIT ──────────────────────────────────────────────────────
const now = new Date();
document.getElementById('selMonth').value = now.getMonth();
