// ── FIREBASE REALTIME SUBSCRIPTION ───────────────────────────
// We subscribe to the entire month's node. Firebase pushes updates
// instantly — so when ANY user saves, everyone sees it live.
function dbKey() {
  const { month, year } = getMonthYear();
  // Encode property names: Firebase keys can't have . / [ ] # $
  return `duty/${year}_${month}`;
}

function subscribeToMonth() {
  // Detach previous listener
  if (activeListener) {
    off(activeListener.ref);
    activeListener = null;
  }

  showLoading('Loading…');
  setSyncBadge('syncing');

  const monthRef = ref(db, dbKey());
  activeListener = { ref: monthRef };

  onValue(monthRef, (snapshot) => {
    monthData = snapshot.val() || {};
    hideLoading();
    setSyncBadge('connected');
    renderSidebar();
    renderGrid();
    if (isReviewMode) renderReview();
  }, (error) => {
    hideLoading();
    setSyncBadge('disconnected');
    toast('❌ Database error: ' + error.message);
  });
}

// ── SAVE A SINGLE CELL ────────────────────────────────────────
// We debounce 600ms per cell so rapid typing doesn't spam Firebase.
// Firebase path: duty/YEAR_MONTH/TAB/PROP_ENCODED/DATE_KEY
function encodeKey(str) {
  // Firebase path segments can't contain . # $ [ ] /
  return str.replace(/\./g,'__DOT__')
            .replace(/#/g,'__HASH__')
            .replace(/\$/g,'__DOLLAR__')
            .replace(/\[/g,'__LB__')
            .replace(/\]/g,'__RB__')
            .replace(/\//g,'__SLASH__')
            .replace(/&/g,'__AMP__');
}

function decodeKey(str) {
  return str.replace(/__DOT__/g,'.')
            .replace(/__HASH__/g,'#')
            .replace(/__DOLLAR__/g,'$')
            .replace(/__LB__/g,'[')
            .replace(/__RB__/g,']')
            .replace(/__SLASH__/g,'/')
            .replace(/__AMP__/g,'&');
}

function saveCell(tab, prop, dateKey, val) {
  const encodedProp = encodeKey(prop);
  const encodedDate = encodeKey(dateKey);
  const cellRef = ref(db, `${dbKey()}/${tab}/${encodedProp}/${encodedDate}`);

  const qKey = `${tab}|${prop}|${dateKey}`;
  pendingSaves.add(qKey);
  setSyncBadge('syncing');

  const promise = val
    ? set(cellRef, val)
    : remove(cellRef);

  promise.then(() => {
    pendingSaves.delete(qKey);
    showSavedDot(dateKey, false);
    if (pendingSaves.size === 0) {
      markSaved();
      setSyncBadge('connected');
    }
  }).catch(err => {
    pendingSaves.delete(qKey);
    setSyncBadge('connected');
    toast('❌ Save failed: ' + err.message);
  });
}

// ── HELPERS ───────────────────────────────────────────────────
function getMonthYear() {
  return {
    month: parseInt(document.getElementById('selMonth').value),
    year:  parseInt(document.getElementById('selYear').value),
  };
}

// Access monthData using encoded keys (Firebase stores encoded, we decode on read)
function getValue(tab, prop, dateKey) {
  const ep = encodeKey(prop);
  const ed = encodeKey(dateKey);
  return (monthData[tab] && monthData[tab][ep] && monthData[tab][ep][ed]) || '';
}

function getDates(month, year, mode) {
  const count = new Date(year, month + 1, 0).getDate();
  const days = [];
  for (let d = 1; d <= count; d++) {
    const date = new Date(year, month, d);
    const dow  = date.getDay();
    const isWeekend = dow === 0 || dow === 6;
    const key  = `${year}-${month+1}-${d}`;
    const isHoliday = !!PH_HOLIDAYS[key];
    if (mode === 'wh' && !isWeekend && !isHoliday) continue;
    days.push({ d, dow, isWeekend, isHoliday, holidayName: PH_HOLIDAYS[key]||null, key });
  }
  return days;
}

function dateLabel(d, month) {
  return `${MONTH_NAMES[month].slice(0,3)}-${d}`;
}

function propStats(tab, prop) {
  const { month, year } = getMonthYear();
  const dates = getDates(month, year, TABS[tab].mode);
  let filled = 0;
  for (const day of dates) {
    if (getValue(tab, prop, day.key)) filled++;
  }
  return { total: dates.length, filled };
}

function tabStats(tab) {
  let total = 0, filled = 0;
  for (const p of PROPERTIES[tab]) {
    const s = propStats(tab, p);
    total += s.total; filled += s.filled;
  }
  return { total, filled };
}

function escH(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── SIDEBAR ───────────────────────────────────────────────────
function renderSidebar() {
  const sb = document.getElementById('sidebar');
  sb.innerHTML = '<div class="sidebar-label">Properties</div>';
  for (const prop of PROPERTIES[currentTab]) {
    const { total, filled } = propStats(currentTab, prop);
    const isActive   = currentProp === prop;
    const isComplete = filled === total && total > 0;
    const btn = document.createElement('button');
    btn.className = `prop-btn${isActive?' active':''}${isComplete?' prop-complete':''}`;
    btn.title = prop;
    btn.innerHTML = `<span class="prop-name">${escH(prop)}</span><span class="fill-badge">${filled}/${total}</span>`;
    btn.onclick = () => { currentProp = prop; renderSidebar(); renderGrid(); };
    sb.appendChild(btn);
  }
}

// ── GRID ──────────────────────────────────────────────────────
function renderGrid() {
  const area = document.getElementById('gridArea');
  if (!currentProp) {
    area.innerHTML = `<div class="empty-state"><div class="empty-icon">👈</div>
      <div class="empty-title">Select a property</div>
      <div class="empty-sub">Choose from the left panel to begin entering names.</div></div>`;
    return;
  }
  const { month, year } = getMonthYear();
  const dates = getDates(month, year, TABS[currentTab].mode);
  const { total, filled } = propStats(currentTab, currentProp);
  const pct = total ? Math.round((filled/total)*100) : 0;

  let html = `
    <div class="legend-bar">
      <strong style="font-size:11px;color:var(--text2);margin-right:4px">Legend:</strong>
      <div class="legend-item"><div class="legend-swatch swatch-regular"></div><span>Regular Day</span></div>
      <div class="legend-item"><div class="legend-swatch swatch-weekend"></div><span style="color:var(--warn)">Weekend (Sat/Sun)</span></div>
      <div class="legend-item"><div class="legend-swatch swatch-holiday"></div><span style="color:var(--accent2)">🇵🇭 PH Public Holiday</span></div>
    </div>
    <div class="progress-header">
      <span class="progress-info"><strong style="color:var(--text)">${escH(currentProp)}</strong> — ${filled}/${total} filled (${pct}%)</span>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
    </div>
    <div class="date-grid">`;

  for (const day of dates) {
    const val = getValue(currentTab, currentProp, day.key);
    const rc  = day.isHoliday ? 'holiday' : (day.isWeekend ? 'weekend' : '');
    const hv  = val ? 'has-value' : '';
    html += `
      <div class="date-row ${rc} ${hv}" id="row_${day.key}">
        <div class="date-label">${dateLabel(day.d, month)}</div>
        <div class="day-label">${DAY_NAMES[day.dow]}</div>
        ${day.isHoliday ? `<span class="holiday-name">🇵🇭 ${day.holidayName}</span>` : ''}
        <input class="name-input${val?' filled':''}" type="text"
          placeholder="Enter officer name…" value="${escH(val)}"
          data-key="${day.key}" oninput="handleInput(this)"
          autocomplete="off" spellcheck="false">
        <div class="saving-dot" id="dot_${day.key}"></div>
        <button class="clear-btn" title="Clear" onclick="clearCell('${day.key}')">✕</button>
      </div>`;
  }
  html += `</div>`;
  area.innerHTML = html;
}

// ── INPUT HANDLING ────────────────────────────────────────────
window.handleInput = function(input) {
  const key = input.dataset.key;
  const val = input.value.trim();

  // Update local mirror instantly so UI feels snappy
  const ep = encodeKey(currentProp);
  const ed = encodeKey(key);
  if (!monthData[currentTab]) monthData[currentTab] = {};
  if (!monthData[currentTab][ep]) monthData[currentTab][ep] = {};
  if (val === '') delete monthData[currentTab][ep][ed];
  else monthData[currentTab][ep][ed] = val;

  const row = document.getElementById('row_' + key);
  if (row) { row.classList.toggle('has-value', !!val); }
  input.classList.toggle('filled', !!val);
  renderSidebar();

  showSavedDot(key, true);

  // Debounce save per cell
  clearTimeout(saveTimers[key]);
  saveTimers[key] = setTimeout(() => {
    saveCell(currentTab, currentProp, key, val);
  }, 600);
};

window.clearCell = function(key) {
  const input = document.querySelector(`input[data-key="${key}"]`);
  if (input) { input.value = ''; input.classList.remove('filled'); }
  const row = document.getElementById('row_' + key);
  if (row) row.classList.remove('has-value');

  const ep = encodeKey(currentProp);
  const ed = encodeKey(key);
  if (monthData[currentTab] && monthData[currentTab][ep]) {
    delete monthData[currentTab][ep][ed];
  }
  renderSidebar();
  saveCell(currentTab, currentProp, key, '');
};

function showSavedDot(key, show) {
  const dot = document.getElementById('dot_' + key);
  if (dot) dot.classList.toggle('active', show);
}

function markSaved() {
  const now = new Date();
  document.getElementById('lastSaved').textContent =
    now.toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const el = document.getElementById('saveStatus');
  el.textContent = '✓ Saved';
  clearTimeout(el._t);
  el._t = setTimeout(() => el.textContent = '', 2500);
}

// ── TAB SWITCH ────────────────────────────────────────────────
window.switchTab = function(tab, el) {
  currentTab  = tab;
  currentProp = PROPERTIES[tab][0];
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  renderSidebar();
  renderGrid();
};

// ── REVIEW ────────────────────────────────────────────────────
window.toggleView = function() {
  isReviewMode = !isReviewMode;
  document.getElementById('btnReview').textContent = isReviewMode ? '✏️ Edit Mode' : '👁 Review';
  document.getElementById('inputView').style.display  = isReviewMode ? 'none' : 'block';
  document.getElementById('reviewView').style.display = isReviewMode ? 'block' : 'none';
  // monthData is already live — no extra fetch needed!
  if (isReviewMode) renderReview();
};

function renderReview() {
  const { month, year } = getMonthYear();
  const ml = `${MONTH_NAMES[month]} ${year}`;

  let totalCells = 0, filledCells = 0;
  for (const tk of Object.keys(TABS)) {
    const { total, filled } = tabStats(tk);
    totalCells += total; filledCells += filled;
  }
  const pct = totalCells ? Math.round((filledCells/totalCells)*100) : 0;

  let html = `
    <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:4px">
      <div>
        <div class="review-title">📋 Master File — ${ml}</div>
        <div class="review-subtitle">Philippine Duty Roster · ${filledCells}/${totalCells} entries (${pct}% complete)</div>
      </div>
      <div style="flex:1"></div>
      <button class="btn btn-primary" onclick="exportCSV()">⬇ Export CSV</button>
      <button class="btn btn-ghost" onclick="exportJSON()">⬇ JSON</button>
    </div>
    <div class="stats-bar">
      <div class="stat-card"><div class="stat-num" style="color:var(--green)">${filledCells}</div><div class="stat-label">Entries Filled</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--red)">${totalCells-filledCells}</div><div class="stat-label">Missing</div></div>
      <div class="stat-card"><div class="stat-num">${pct}%</div><div class="stat-label">Completion</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--text3)">${totalCells}</div><div class="stat-label">Total Slots</div></div>
    </div>
    <div class="toolbar">
      <input class="search-input" type="text" placeholder="🔍 Search name or property…"
        value="${escH(searchQuery)}" oninput="reviewSearch(this.value)">
      <button class="filter-btn${reviewFilter==='all'?' active':''}" onclick="setFilter('all')">All</button>
      <button class="filter-btn${reviewFilter==='filled'?' active':''}" onclick="setFilter('filled')">Filled Only</button>
      <button class="filter-btn${reviewFilter==='empty'?' active':''}" onclick="setFilter('empty')">Missing Only</button>
    </div>`;

  for (const [tk, ti] of Object.entries(TABS)) {
    const { total: st, filled: sf } = tabStats(tk);
    const sPct = st ? Math.round((sf/st)*100) : 0;
    const dates = getDates(month, year, ti.mode);
    const props = PROPERTIES[tk];

    html += `
      <div class="review-section">
        <div class="review-section-title">
          <span style="color:${ti.color}">●</span>${ti.label}
          <span style="margin-left:auto;font-size:10px;font-weight:400;color:var(--text3)">${sf}/${st} (${sPct}%)</span>
        </div>
        <div class="review-table-wrap">
        <table class="review-table">
          <thead><tr><th>Date</th><th>Day</th><th>Type</th>`;
    for (const p of props) html += `<th>${escH(p)}</th>`;
    html += `</tr></thead><tbody>`;

    for (const day of dates) {
      const type = day.isHoliday ? 'Holiday' : (day.isWeekend ? 'Weekend' : 'Regular');
      const rc   = day.isHoliday ? 'holiday-row' : (day.isWeekend ? 'weekend-row' : '');
      let rowVis = false;
      let cellsHtml = '';

      for (const p of props) {
        const val = getValue(tk, p, day.key);
        const matchSearch = !searchQuery
          || val.toLowerCase().includes(searchQuery.toLowerCase())
          || p.toLowerCase().includes(searchQuery.toLowerCase())
          || dateLabel(day.d, month).toLowerCase().includes(searchQuery.toLowerCase());
        if (!matchSearch) { cellsHtml += `<td class="empty-cell">—</td>`; continue; }
        const showFilled = reviewFilter === 'filled' && !!val;
        const showEmpty  = reviewFilter === 'empty'  && !val;
        const showAll    = reviewFilter === 'all';
        if (showAll || showFilled || showEmpty) rowVis = true;
        cellsHtml += val
          ? `<td class="filled-cell">${escH(val)}</td>`
          : `<td class="empty-cell">—</td>`;
      }
      if (!rowVis && (reviewFilter !== 'all' || searchQuery)) continue;

      html += `<tr class="${rc}">
        <td style="font-family:var(--mono);font-size:10px;white-space:nowrap">
          ${dateLabel(day.d, month)}
          ${day.isHoliday ? `<br><span style="font-size:9px;color:var(--accent2)">${day.holidayName}</span>` : ''}
        </td>
        <td>${DAY_NAMES[day.dow]}</td>
        <td><span style="font-size:9px;padding:2px 5px;border-radius:3px;
          background:${day.isHoliday?'rgba(139,92,246,0.15)':day.isWeekend?'rgba(245,158,11,0.12)':'var(--surface3)'};
          color:${day.isHoliday?'var(--accent2)':day.isWeekend?'var(--warn)':'var(--text3)'}">${type}</span></td>
        ${cellsHtml}</tr>`;
    }
    html += `</tbody></table></div></div>`;
  }
  document.getElementById('reviewContent').innerHTML = html;
}

window.reviewSearch = function(q) { searchQuery = q; renderReview(); };
window.setFilter    = function(f) { reviewFilter = f; renderReview(); };

// ── EXPORT ────────────────────────────────────────────────────
window.exportCSV = function() {
  const { month, year } = getMonthYear();
  const ml   = `${MONTH_NAMES[month]}_${year}`;
  const rows = [['Tab','Property','Date','Day','Type','Officer / Name']];

  for (const [tk, ti] of Object.entries(TABS)) {
    const dates = getDates(month, year, ti.mode);
    for (const p of PROPERTIES[tk]) {
      for (const day of dates) {
        const val  = getValue(tk, p, day.key);
        const type = day.isHoliday ? 'Holiday' : (day.isWeekend ? 'Weekend' : 'Regular');
        rows.push([ti.label, p, dateLabel(day.d, month), DAY_NAMES[day.dow], type, val]);
      }
    }
  }
  const csv  = rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  dlBlob(blob, `Duty_Tracker_${ml}.csv`);
  toast('✓ CSV downloaded — ' + ml.replace('_',' '));
};

window.exportJSON = function() {
  const { month, year } = getMonthYear();
  const ml   = `${MONTH_NAMES[month]}_${year}`;
  // Decode keys before exporting so JSON is human-readable
  const decoded = {};
  for (const [tk, tData] of Object.entries(monthData)) {
    decoded[tk] = {};
    for (const [ep, pData] of Object.entries(tData)) {
      const p = decodeKey(ep);
      decoded[tk][p] = {};
      for (const [ed, val] of Object.entries(pData)) {
        decoded[tk][p][decodeKey(ed)] = val;
      }
    }
  }
  const blob = new Blob([JSON.stringify(decoded, null, 2)], {type:'application/json'});
  dlBlob(blob, `Duty_Tracker_${ml}.json`);
  toast('✓ JSON downloaded — ' + ml.replace('_',' '));
};

function dlBlob(blob, name) {
  const url = URL.createObjectURL(blob);
  const a   = document.createElement('a');
  a.href = url; a.download = name;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

